---
import Layout from '@/layouts/Empty.astro'
import { Icon } from 'astro-icon/components'
---

<Layout>
    <div class="flex h-dvh w-full flex-col items-center justify-center gap-2">
        <p
            class="flex items-center gap-1 font-medium text-neutral-700 dark:text-neutral-200"
        >
            <Icon name="ph:warning" size={18} /> The page you're looking for is not
            found!
        </p>

        <a
            href="/"
            class="group flex items-center gap-2 rounded-2xl border border-indigo-500 bg-linear-to-t from-indigo-600 to-indigo-500 px-8 py-4 text-sm font-medium transition-all hover:brightness-110 active:scale-95"
        >
            <Icon name="ph:arrow-left" size={20} />
            Return
        </a>
    </div>
</Layout>
