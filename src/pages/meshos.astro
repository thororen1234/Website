---
// src/pages/meshos.astro
import '@/styles/global.css'
import Head from '@/components/Layout/Head.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import Box from '@/components/Base/Box.astro'
import { Link, ExternalLink } from '@lucide/astro'
---

<!doctype html>
<html lang="en">
    <head>
        <Head
            title="MeshOS Keygen"
            description="MeshOS Keygen to generate device keys."
        />
        <link rel="icon" type="image/png" href="/meshos/meshos.png" />
    </head>
    <body class="flex min-h-screen items-center justify-center p-4">
        <ThemeToggle />

        <div class="w-full max-w-md font-mono">
            <Box class="flex flex-col gap-4">
                <div
                    class="mb-2 text-sm font-bold tracking-widest text-neutral-800 dark:text-neutral-200"
                >
                    MeshOS Keygen
                </div>

                <input
                    id="mk-in"
                    type="text"
                    placeholder="Android ID / Device ID"
                    class="w-full rounded-lg border border-zinc-300 bg-zinc-50 p-3 text-neutral-800 outline-none focus:border-neutral-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-neutral-200 dark:focus:border-neutral-500"
                />

                <button
                    id="mk-go"
                    class="w-full cursor-pointer rounded-lg border border-zinc-300 bg-zinc-200 p-3 font-bold tracking-widest text-neutral-800 transition-colors hover:bg-zinc-300 dark:border-zinc-700 dark:bg-zinc-800 dark:text-neutral-200 dark:hover:bg-zinc-700"
                >
                    Generate
                </button>

                <div
                    id="mk-out"
                    class="mt-2 flex min-h-12 items-center justify-center rounded-lg bg-zinc-200 p-3 text-center tracking-widest break-all text-neutral-800 dark:bg-zinc-950 dark:text-neutral-200"
                >
                </div>

                <div
                    class="mt-2 flex flex-col gap-4 border-t border-zinc-300 pt-4 dark:border-zinc-800"
                >
                    <div class="flex flex-col gap-1">
                        <span
                            class="text-xs font-bold tracking-wider text-neutral-500 dark:text-neutral-400"
                            >MeshOS Apk</span
                        >
                        <div class="flex flex-wrap gap-2 text-sm">
                            <a
                                href="https://thororen.com/meshos/meshos.apk"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                            >
                                Direct
                            </a>
                            <span
                                class="text-neutral-300 dark:text-neutral-700"
                            >
                                |
                            </span>
                            <a
                                href="https://meshoskey.com/MeshOS-v1.0.0.apk"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                            >
                                Mirror 1
                            </a>
                            <span
                                class="text-neutral-300 dark:text-neutral-700"
                            >
                                |
                            </span>
                            <a
                                href="https://github.com/andymux/meshos-releases/releases/download/v1.0.0/app-release.apk"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                            >
                                GitHub
                            </a>
                        </div>
                    </div>

                    <div class="flex flex-col gap-1">
                        <span
                            class="text-xs font-bold tracking-wider text-neutral-500 dark:text-neutral-400"
                            >MeshOS Bin</span
                        >
                        <div class="flex flex-wrap gap-2 text-sm">
                            <a
                                href="https://thororen.com/meshos/meshos.bin"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                                >Direct</a
                            >
                            <span class="text-neutral-300 dark:text-neutral-700"
                                >|</span
                            >
                            <a
                                href="https://meshoskey.com/MeshOS-TDeck-1.1.8.bin"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                                >Mirror 1</a
                            >
                            <span class="text-neutral-300 dark:text-neutral-700"
                                >|</span
                            >
                            <a
                                href="https://ndl1s62ywx.pages.dev/MeshOS-TDeck-1.1.8.bin"
                                target="_blank"
                                class="text-sky-600 hover:underline dark:text-sky-400"
                                >Mirror 2</a
                            >
                        </div>
                    </div>

                    <div class="pt-1">
                        <a
                            href="https://meshoskey.com/"
                            target="_blank"
                            class="inline-flex items-center gap-1.5 text-sm font-medium text-neutral-600 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100"
                        >
                            <Link size={16} />
                            <span>More info about this keygen and MeshOS </span>
                        </a>
                    </div>
                </div>
            </Box>
        </div>

        <script>
            const input = document.getElementById('mk-in') as HTMLInputElement
            const button = document.getElementById('mk-go')
            const output = document.getElementById('mk-out')

            function gen(id: string) {
                let s = id.replace(/[:\- \\]/g, ''),
                    h = 0
                for (let i = 0; i < s.length; i++)
                    h = (h * 33 + s.charCodeAt(i)) >>> 0
                let b = [
                    ((h >>> 24) & 0xff) ^ 0x4d,
                    ((h >>> 16) & 0xff) ^ 0x43,
                    ((h >>> 8) & 0xff) ^ 0x50,
                    (h & 0xff) ^ 0x50,
                ]
                return b.map((x) => x.toString(16).padStart(2, '0')).join('')
            }

            function run() {
                if (!input || !output) return
                const v = input.value.trim()
                output.textContent = v ? gen(v) : '// enter an id'
            }

            if (button && input) {
                button.addEventListener('click', run)
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') run()
                })
            }
        </script>
    </body>
</html>
