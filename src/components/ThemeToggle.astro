---
import { Icon } from 'astro-icon/components'
---

<button
    id="theme-toggle"
    class="absolute top-3 left-3 flex size-10 cursor-pointer items-center justify-center rounded-lg border border-zinc-300 bg-zinc-100 text-neutral-600 transition-transform hover:bg-zinc-300 active:scale-95 dark:border-zinc-800 dark:bg-zinc-900 dark:text-neutral-200 dark:hover:bg-zinc-800"
>
    <Icon name="ph:sun" size={18} class="hidden dark:block" />
    <Icon name="ph:moon" size={18} class="block dark:hidden" />
</button>

<script>
    import type { Theme } from '@/types'
    import { getTheme, setTheme } from '@/utils/theme'
    import { onClick, setRootAttribute } from '@/utils/dom'

    function toggleTheme(): void {
        const current = getTheme()
        const newTheme: Theme = current === 'dark' ? 'light' : 'dark'
        setTheme(newTheme)
        setRootAttribute('data-theme', newTheme)
    }

    setRootAttribute('data-theme', getTheme())

    onClick<HTMLButtonElement>('theme-toggle', () => {
        toggleTheme()
    })
</script>
