---
import { BookMarked, Github, Heart } from '@lucide/astro'
import { Socials } from '@/consts'
import Box from '@/components/Base/Box.astro'
---

<span class="flex items-center gap-1 text-sm font-medium text-neutral-600 dark:text-neutral-400">
    <BookMarked size="18" /> Socials
</span>

<a
    href="https://github.com/sponsors/thororen1234"
    target="_blank"
    class="group relative flex flex-1 items-center gap-2 overflow-hidden rounded-2xl border border-rose-800 bg-linear-to-t from-rose-800 to-rose-600 px-8 py-4 text-sm font-medium transition-all hover:brightness-110 active:scale-95"
>
    <Github size={20} />
    <span class="transition-colors group-hover:text-rose-300">Github Sponsors</span>
    <Heart
        size={128}
        class="absolute -top-6 -right-6 mask-b-from-10% opacity-20 transition-transform duration-700 group-hover:-translate-x-2"
    />
</a>

<Box>
    {
        Socials.map((social) => (
            <a
                href={social.url}
                target="_blank"
                class="flex items-center gap-1 font-medium text-neutral-700 transition-colors hover:text-rose-500 dark:text-neutral-200"
            >
                <social.icon size="18" width="18" height="18" />
                {social.text}
            </a>
        ))
    }
</Box>
