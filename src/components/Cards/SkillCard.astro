---
import type { Skill } from '@/types'
import { Icon } from 'astro-icon/components'

const { text, description, progress } = Astro.props as Skill

const progressWidth = `width: ${progress}%;`
---

<div class="flex flex-col">
    <!-- Title -->
    <h4 class="font-medium text-neutral-700 dark:text-neutral-200">
        {text}
    </h4>

    <!-- Description -->
    <p
        class="text-sm leading-6 text-neutral-500 dark:text-neutral-400"
    >
        <Icon name="ph:stack" size={16}  class="inline" />
        {description}
    </p>

    <!-- Progress -->
    <div class="mt-2 h-4 w-full rounded-2xl bg-zinc-200 dark:bg-zinc-800">
        <div
            style={progressWidth}
            class="h-full rounded-2xl bg-linear-to-r from-indigo-600 to-indigo-500 outline-1 outline-indigo-500"
        >
        </div>
    </div>
</div>
